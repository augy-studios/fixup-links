BOT_TOKEN=your-bot-token-here

# Used only to build the "@username <link>" inline-mode example in /start -
# not referenced by any command's actual logic.
BOT_USERNAME=uwuFix_bot

DB_PATH=./data/linkfix_bot.sqlite3
SCHEDULER_DB_PATH=./data/scheduler.sqlite3
WEB_APP_URL=https://fixup.uwuapps.org
DONATE_URL=https://donate.stripe.com/28o2akeAr3hv0DK6oo
DISCORD_INVITE_URL=https://discord.com/oauth2/authorize?client_id=1524465330091724880

# /batch caps how many links it will process from one message.
MAX_BATCH_LINKS=30

# Default automatic link-fixing behavior for new group chats. Group admins
# can override this per-chat with /settings; the choice is stored in SQLite.
AUTODETECT_DEFAULT=true

# How often (in minutes) the bot refreshes its short description with a
# "cleaning links in N chats" stat. The schedule itself is persisted in
# SCHEDULER_DB_PATH so it survives restarts.
BIO_UPDATE_INTERVAL_MINUTES=30

# Only set this if the VPS can't reach api.telegram.org directly (e.g.
# Telegram is blocked/throttled by the hosting provider or country the VPS
# is in) and you're seeing "Timed out" errors on startup. See SETUP.md's
# troubleshooting section. e.g. socks5://user:pass@host:1080 or
# http://host:8080. Leave blank to connect directly.
TELEGRAM_PROXY_URL=
