DISCORD_TOKEN=your-bot-token-here

# Optional: set to a single guild ID during development so slash commands
# sync instantly instead of waiting up to an hour for the global sync.
GUILD_ID=

DB_PATH=./data/uwufix_bot.sqlite3
WEB_APP_URL=https://fixup.uwuapps.org
DONATE_URL=https://donate.stripe.com/28o2akeAr3hv0DK6oo

# The /batch reply has 1 "Copy All" button, and Discord caps a message at
# 25 components total, so this should not exceed 25 - 1 = 24.
MAX_BATCH_LINKS=24
